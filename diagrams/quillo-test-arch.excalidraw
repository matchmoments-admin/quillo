      "updated": 1,
      "link": null,
      "locked": false,
      "text": "\u2022  On phone: app.quillo.au \u2192 '+ Add receipt' \u2192 snap. Expect merchant/amount/GST within ~5s.\n\u2022  Bulk/offline: node scripts/feed-expenses.mjs <folder|file>.\n\u2022  Verify in Inbox \u2192 tap row \u2192 fields + receipt image + confidence.",
      "fontSize": 12,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "\u2022  On phone: app.quillo.au \u2192 '+ Add receipt' \u2192 snap. Expect merchant/amount/GST within ~5s.\n\u2022  Bulk/offline: node scripts/feed-expenses.mjs <folder|file>.\n\u2022  Verify in Inbox \u2192 tap row \u2192 fields + receipt image + confidence.",
      "lineHeight": 1.25
    },
