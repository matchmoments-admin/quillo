{
  "name": "tax-agent",
  "private": true,
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "schema": "wrangler d1 execute tax-agent-db --file=schema.sql",
    "schema:local": "wrangler d1 execute tax-agent-db --local --file=schema.sql",
    "eval": "promptfoo eval -c evals/promptfooconfig.yaml --output evals/results.json",
    "eval:view": "promptfoo view",
    "eval:gate": "node scripts/check-eval-baseline.mjs",
    "eval:export": "node scripts/export-evals.mjs",
    "rulepack:push": "node scripts/push-rulepack.mjs src/rulepacks/au-v1.json",
    "onboard": "node scripts/onboard.mjs",
    "preflight": "node scripts/preflight.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40.1",
    "agents": "^0.0.80",
    "postal-mime": "^2.4.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260401.0",
    "promptfoo": "^0.110.0",
    "typescript": "^5.6.3",
    "wrangler": "^3.90.0"
  }
}
