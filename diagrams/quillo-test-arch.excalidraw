      "updated": 1,
      "link": null,
      "locked": false,
      "text": "\u2022  Import a big statement \u2192 account shows 'categorising\u2026', then 'imported (n)'.\n\u2022  Status polls every 5s while categorising; failure \u2192 red 'failed' + alert.\n\u2022  Unit guard: npm run test:units (batchStatementStatus / isStaleBatch).",
      "fontSize": 12,
      "fontFamily": 2,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "\u2022  Import a big statement \u2192 account shows 'categorising\u2026', then 'imported (n)'.\n\u2022  Status polls every 5s while categorising; failure \u2192 red 'failed' + alert.\n\u2022  Unit guard: npm run test:units (batchStatementStatus / isStaleBatch).",
      "lineHeight": 1.25
    },
