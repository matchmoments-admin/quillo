{
  "name": "tax-agent",
  "private": true,
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "schema": "wrangler d1 execute tax-agent-db --file=schema.sql",
    "schema:local": "wrangler d1 execute tax-agent-db --local --file=schema.sql",
    "eval": "promptfoo eval -c evals/promptfooconfig.yaml --output evals/results.json --no-write",
    "eval:view": "promptfoo view",
    "eval:gate": "node scripts/check-eval-baseline.mjs",
    "eval:ci": "npm run eval; node scripts/check-eval-baseline.mjs",
    "eval:export": "node scripts/export-evals.mjs",
    "eval:statements": "tsx scripts/check-statements.ts",
    "test:units": "tsx scripts/check-units.ts",
    "test:personas": "tsx scripts/check-personas.ts",
    "test:au-snapshot": "tsx scripts/check-au-snapshot.ts",
    "test:schema": "tsx scripts/check-schema-drift.ts",
    "test": "npm run test:units && npm run test:personas && npm run test:au-snapshot && npm run eval:statements && npm run test:schema",
    "rulepack:push": "node scripts/push-rulepack.mjs src/rulepacks/au-v1.json",
    "onboard": "node scripts/onboard.mjs",
    "preflight": "node scripts/preflight.mjs",
    "web:install": "cd web && npm install",
    "web:build": "cd web && npm run build",
    "web:dev": "cd web && npm run dev"
  },
  "dependencies": {
    "@anthropic-ai/bedrock-sdk": "^0.29.2",
    "@anthropic-ai/sdk": "^0.40.1",
    "@cantoo/pdf-lib": "^2.7.1",
    "agents": "^0.0.80",
    "fflate": "^0.8.3",
    "jose": "^5.9.6",
    "postal-mime": "^2.4.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260401.0",
    "promptfoo": "^0.110.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.3",
    "wrangler": "^4.20.0"
  }
}
